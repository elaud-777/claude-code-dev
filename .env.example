# Copy to .env and adjust as needed. docker-compose.yml reads these.

# --- Backend ---
# Local default: SQLite file under a persisted volume.
# For Postgres (Neon or the local `postgres` compose service):
#   DATABASE_URL=postgres://taskflow:taskflow@postgres:5432/taskflow?sslmode=disable
DATABASE_URL=sqlite:///./data/taskflow.db

# CHANGE THIS in any non-local environment.
JWT_SECRET=dev-secret-change-in-production

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

BACKEND_PORT=8000
FRONTEND_PORT=3000
