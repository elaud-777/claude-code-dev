# Copy to .env and adjust as needed. docker-compose.yml reads these.

# --- Backend ---
# Default: the `postgres` service in docker-compose.yml — a container
# running on this machine, not an external/cloud DB. To use plain SQLite
# instead (single container, no separate DB service; fine for solo local
# dev), set: DATABASE_URL=sqlite:///./data/taskflow.db
DATABASE_URL=postgres://taskflow:taskflow@postgres:5432/taskflow?sslmode=disable

# CHANGE THIS in any non-local environment.
JWT_SECRET=dev-secret-change-in-production

# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

BACKEND_PORT=8000
FRONTEND_PORT=3000
